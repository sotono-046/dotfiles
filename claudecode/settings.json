{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": false,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "afplay /System/Library/Sounds/Pop.aiff",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "/Users/sotono/.caudex/hooks/session-hook.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "/Users/sotono/.caudex/hooks/session-hook.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "/Users/sotono/.caudex/hooks/session-hook.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/Users/sotono/.caudex/hooks/session-hook.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "afplay /System/Library/Sounds/Hero.aiff",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "/Users/sotono/.caudex/hooks/session-hook.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "language": "Japanese",
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Read",
      "Write(//Users/sotono/dotfiles/**)",
      "Edit(//Users/sotono/dotfiles/**)",
      "Bash(claude -p:*)",
      "Bash(gh issue:*)",
      "Bash(mkdir -p:*)",
      "Bash(wc:*)",
      "Bash(wtp:*)",
      "Bash(pnpm:*)",
      "Bash(gcloud:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(gh pr:*)",
      "mcp__serena",
      "mcp__playwright",
      "mcp__codex",
      "mcp__context7",
      "Write(//Users/sotono/Documents/**)",
      "Edit(//Users/sotono/Documents/**)",
      "Bash(coderabbit:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release:*)"
    ],
    "defaultMode": "default",
    "deny": []
  },
  "plansDirectory": "./.temp/plans",
  "statusLine": {
    "command": "tee \"/Users/sotono/.caudex/status-data.json\" | bunx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  }
}