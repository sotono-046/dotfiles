<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>dev.sotono.hdd-keepalive-watcher</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/sotono/bin/hdd-keepalive-watcher.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>30</integer>
  <key>StandardOutPath</key>
  <string>/tmp/hdd-keepalive-watcher.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/hdd-keepalive-watcher-error.log</string>
</dict>
</plist>
