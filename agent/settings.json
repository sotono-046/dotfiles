      "Bash(gh release:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opusplan",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Pop.aiff"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notification-discord.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/stop-discord.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-start-discord.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-end-discord.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true,
    "fairy-tale@fairy-tale-marketplace": true
  },
  "extraKnownMarketplaces": {
    "fairy-tale-marketplace": {
      "source": {
        "source": "github",
        "repo": "bonginkan/fairy_tale"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium",
  "plansDirectory": "./.temp/plans",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "teammateMode": "in-process",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
